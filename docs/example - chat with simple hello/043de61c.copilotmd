        },
        "type": "function",
        "strict": false
    },
    {
        "name": "open_browser_page",
        "description": "Open a new browser page in the integrated browser at the given URL.",
        "parameters": {
            "type": "object",
            "properties": {
                "url": {
                    "type": "string",
