    {
        "name": "manage_todo_list",
        "description": "Updates the task plan.\nProvide an optional explanation and a list of plan items, each with a step and status.\nAt most one step can be in_progress at a time.",
        "parameters": {
            "type": "object",
            "properties": {
                "todoList": {
                    "type": "array",
